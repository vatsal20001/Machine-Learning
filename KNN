from sklearn.neighbors import KNeighborsClassifier

# Training data (features)
X = [[1, 2], [2, 3], [3, 1], [6, 5], [7, 7], [8, 6]]

# Labels
y = [0, 0, 0, 1, 1, 1]

# Create model (k = 3)
knn = KNeighborsClassifier(n_neighbors=3)

# Train model
knn.fit(X, y)

# Predict new data
prediction = knn.predict([[5, 5]])

print("Prediction:", prediction)
